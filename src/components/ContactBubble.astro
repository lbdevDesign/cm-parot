---
// Composant bulle de contact urgence
---

<!-- Bulle flottante -->
<div class="fixed bottom-6 right-6 z-50">
  <button
    id="open-contact-modal"
    class="flex items-center cursor-pointer justify-center w-16 h-16 text-white rounded-full shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-110 group"
    style="background: linear-gradient(135deg, #EC2525, #b81c1c);"
    aria-label="Numéro d'urgence"
  >
    <svg
      class="h-8 w-8 transition-transform group-hover:scale-110"
      fill="none"
      viewBox="0 0 24 24"
      stroke="white"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path
        d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
      ></path>
    </svg>
  </button>
</div>

<!-- Modale -->
<div
  id="contact-modal"
  class="fixed inset-0 z-[100] pointer-events-none transition-opacity duration-300 flex items-center justify-center p-4"
  style="background-color: rgba(0, 0, 0, 0.5); backdrop-filter: blur(4px); opacity: 0;"
>
  <div
    id="modal-content"
    class="bg-white rounded-2xl shadow-2xl max-w-lg w-full transform scale-95 transition-transform duration-300 overflow-hidden"
  >
    <!-- Header -->
    <div
      class="text-white px-6 py-4 rounded-t-2xl flex justify-between items-center"
      style="background: linear-gradient(135deg, #EC2525, #b81c1c);"
    >
      <h2 class="text-xl font-bold text-white">Consultation urgente</h2>
      <button
        id="close-contact-modal"
        class="text-white hover:bg-white hover:bg-opacity-20 rounded-full p-2 transition-all"
        aria-label="Fermer"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Contenu -->
    <div class="p-6 space-y-4 text-sm text-gray-700">
      <p>
        Pour toute demande de consultation urgente, veuillez adresser de préférence votre demande
        <strong>par mail</strong> en joignant à votre demande le courrier de votre médecin traitant et/ou
        le compte rendu d'imagerie. Ces éléments permettront aux médecins de notre centre d'évaluer le
        degré d'urgence de votre demande et de vous donner un rendez-vous dans les délais adéquats.
      </p>
      <p class="font-medium" style="color: #EC2525;">
        En cas de suspicion de cancer pulmonaire, un rendez-vous sera donné dans un délai de
        quelques jours.
      </p>
      <div class="space-y-3 pt-2 border-t border-gray-100">
        <div>
          <p class="text-xs text-gray-500 mb-1">Hôpital Privé Jean Mermoz</p>
          <a
            href="mailto:secretariat.mermoz@centremedicalparot.fr"
            class="font-medium hover:underline break-all"
            style="color: #EC2525;"
          >
            secretariat.mermoz@centremedicalparot.fr
          </a>
        </div>
        <div>
          <p class="text-xs text-gray-500 mb-1">
            Clinique Charcot, Polyclinique de Rillieux ou cabinet 54 Rue Duquesne
          </p>
          <a
            href="mailto:secretariat@centremedicalparot.fr"
            class="font-medium hover:underline break-all"
            style="color: #EC2525;"
          >
            secretariat@centremedicalparot.fr
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById("contact-modal");
  const modalContent = document.getElementById("modal-content");
  const openBtn = document.getElementById("open-contact-modal");
  const closeBtn = document.getElementById("close-contact-modal");

  function openModal() {
    modal?.classList.remove("pointer-events-none");
    modal?.classList.add("pointer-events-auto");
    if (modal) modal.style.opacity = "1";
    modalContent?.classList.remove("scale-95");
    modalContent?.classList.add("scale-100");
    document.body.style.overflow = "hidden";
  }

  function closeModal() {
    modal?.classList.add("pointer-events-none");
    modal?.classList.remove("pointer-events-auto");
    if (modal) modal.style.opacity = "0";
    modalContent?.classList.add("scale-95");
    modalContent?.classList.remove("scale-100");
    document.body.style.overflow = "";
  }

  openBtn?.addEventListener("click", openModal);
  closeBtn?.addEventListener("click", closeModal);

  modal?.addEventListener("click", (e) => {
    if (e.target === modal) closeModal();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && modal && modal.style.opacity === "1") closeModal();
  });
</script>

<style>
  @keyframes pulse-ring {
    0% {
      box-shadow: 0 0 0 0 rgba(236, 37, 37, 0.7);
    }
    50% {
      box-shadow: 0 0 0 10px rgba(236, 37, 37, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(236, 37, 37, 0);
    }
  }

  #open-contact-modal {
    animation: pulse-ring 2s infinite;
  }
</style>
