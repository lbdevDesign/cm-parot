---
import Link from "../components/Link.astro";
import cabinets from "../data/cabinets.js";

// Préparer les données pour le JS
const cabinetsJSON = JSON.stringify(
  cabinets.map((c) => ({
    id: String(c.id),
    name: c.name,
    district: c.district,
    phone: c.phone || "04 78 77 51 43",
    email: c.email || "secretaria@centremedicalparot.fr",
  }))
);

const firstCabinet = cabinets[0];
---

<section class="relative min-h-screen flex items-center py-20 bg-[#313181]" id="contact">
  <div class="relative z-10 w-full max-w-7xl mx-auto pt-10 mt-10 px-6">
    <div class="grid md:grid-cols-2 gap-12 items-start">
      <!-- Partie gauche : Informations -->
      <div class="space-y-8">
        <div>
          <h1 class="text-3xl md:text-5xl text-white md:text-6xl font-bold mb-4">
            Une question ?<br />
            <span class="text-[#37A4B3]">Contactez-nous</span>
          </h1>
          <p class="text-xl text-white/90">Notre équipe vous répond dans les plus brefs délais</p>
        </div>

        <!-- Sélecteur de cabinet -->
        <div>
          <h3 class="text-white text-lg font-semibold mb-4">Sélectionnez votre cabinet</h3>
          <div class="flex gap-3 flex-wrap">
            {
              cabinets.map((cabinet, index) => (
                <button
                  data-cabinet-id={String(cabinet.id)}
                  class={`cabinet-selector px-6 py-3 rounded-xl font-medium transition-all duration-300 ${
                    index === 0
                      ? "bg-white text-[#313181] shadow-md"
                      : "bg-white/10 text-white border border-white/20 hover:bg-white/20"
                  }`}
                >
                  {cabinet.district}
                </button>
              ))
            }
          </div>
        </div>

        <!-- Infos de contact -->
        <div class="space-y-6 pt-8">
          <div class="flex items-start gap-4">
            <div
              class="flex-shrink-0 w-12 h-12 bg-white/10 backdrop-blur-sm rounded-lg flex items-center justify-center"
            >
              <svg
                class="w-6 h-6 text-[#37A4B3]"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-lg mb-1 text-white">Téléphone</h3>

              <a
                id="contact-phone"
                href={`tel:${(firstCabinet.phone || "04 78 77 51 43").replace(/\s/g, "")}`}
                class="text-white/80 hover:text-[#37A4B3] transition"
              >
                {firstCabinet.phone || "04 78 77 51 43"}
              </a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div
              class="flex-shrink-0 w-12 h-12 bg-white/10 backdrop-blur-sm rounded-lg flex items-center justify-center"
            >
              <svg
                class="w-6 h-6 text-[#37A4B3]"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-lg mb-1 text-white">Email</h3>

              <a
                id="contact-email"
                href={`mailto:${firstCabinet.email || "secretaria@centremedicalparot.fr"}`}
                class="text-white/80 hover:text-[#37A4B3] transition"
              >
                {firstCabinet.email || "secretaria@centremedicalparot.fr"}
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Partie droite : Formulaire -->
      <div class="bg-white rounded-2xl shadow-2xl p-8 md:p-10">
        <h2 class="text-2xl font-bold text-[#313181] mb-6">Envoyez-nous un message</h2>

        <form class="space-y-5">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 mb-2">
              Nom complet
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#37A4B3] focus:border-transparent transition"
              placeholder="Jean Dupont"
            />
          </div>

          <div>
            <label for="email-input" class="block text-sm font-medium text-gray-700 mb-2">
              Email
            </label>
            <input
              type="email"
              id="email-input"
              name="email"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#37A4B3] focus:border-transparent transition"
              placeholder="jean.dupont@email.com"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 mb-2">
              Message
            </label>
            <textarea
              id="message"
              name="message"
              rows="4"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#37A4B3] focus:border-transparent transition resize-none"
              placeholder="Décrivez votre demande..."></textarea>
          </div>

          <button
            type="submit"
            class="w-full px-6 py-3 bg-gradient-to-br from-[#37A4B3] to-[#268090] text-white font-semibold rounded-lg hover:shadow-lg transition-all"
          >
            Envoyer le message
          </button>
        </form>
      </div>
    </div>

    <script define:vars={{ cabinetsJSON }}>
      const cabinetsData = JSON.parse(cabinetsJSON);
      const buttons = document.querySelectorAll(".cabinet-selector");
      const phoneEl = document.getElementById("contact-phone");
      const emailEl = document.getElementById("contact-email");

      buttons.forEach((btn) => {
        btn.addEventListener("click", function () {
          const cabinetId = this.getAttribute("data-cabinet-id");
          const selected = cabinetsData.find((c) => String(c.id) === String(cabinetId));

          if (!selected) return;

          // Mettre à jour les boutons
          buttons.forEach((b) => {
            b.classList.remove("bg-white", "text-[#313181]", "shadow-md");
            b.classList.add("bg-white/10", "text-white", "border", "border-white/20");
          });

          this.classList.add("bg-white", "text-[#313181]", "shadow-md");
          this.classList.remove("bg-white/10", "text-white", "border", "border-white/20");

          // Mettre à jour les infos de contact
          phoneEl.textContent = selected.phone;
          phoneEl.href = `tel:${selected.phone.replace(/\s/g, "")}`;

          emailEl.textContent = selected.email;
          emailEl.href = `mailto:${selected.email}`;
        });
      });
    </script>
  </div>
</section>
