---
import { Image } from "astro:assets"; // ← Bon import
import Link from "./Link.astro";
import cabinets from "../data/cabinets.js";

// Importer les images statiquement pour l'optimisation
import cliniqueDuquesne from "../assets/cabinets/cliniqueDuquesne.jpg";
import cliniqueDuquesneMob from "../assets/cabinets/cliniqueDuquesneMob.jpg";
// ... importe toutes tes images

// Préparer les données pour le JS
const cabinetsJSON = JSON.stringify(
  cabinets.map((c) => ({
    id: String(c.id),
    name: c.name,
    district: c.district,
    description: c.description,
    mapsUrl: c.mapsUrl,
    // Garder seulement les données non-image pour le JSON
  }))
);

let activeCabinetIndex = 0;
---

<section class="w-full scroll-mt-25 pt-10 pb-10" id="cabinets">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="text-3xl md:text-4xl text-[#313181] font-bold text-center mb-4">Nos cabinets</h2>
    <p class="text-center text-gray-600 mb-12">
      Retrouvez nos différents cabinets médicaux répartis dans la ville
    </p>

    <!-- Boutons de sélection -->
    <div class="flex gap-3 justify-center flex-wrap mb-8">
      {
        cabinets.map((cabinet, index) => (
          <button
            data-cabinet-id={String(cabinet.id)}
            aria-label={`Sélectionner le cabinet ${cabinet.district}`}
            class={`cabinet-btn cursor-pointer px-6 py-3 rounded-xl font-medium transition-all duration-300 ${
              index === activeCabinetIndex
                ? "bg-gradient-to-br from-[#37A4B3] to-[#268090] text-white shadow-md"
                : "bg-white text-[#313181] border border-[#37A4B3] hover:shadow-sm hover:bg-gray-100 hover:from-[#37A4B3] hover:to-[#268090]"
            }`}
          >
            {cabinet.district}
          </button>
        ))
      }
    </div>

    <!-- Carte d'affichage -->
    <div
      class="bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-md transition-all duration-300 overflow-hidden"
    >
      <!-- Image en haut -->
      <div class="relative w-full md:h-100 overflow-hidden">
        {
          cabinets.map((cabinet, index) => (
            <>
              {/* Image desktop */}
              <Image
                src={cabinet.image}
                alt={cabinet.name}
                width={1920}
                height={800}
                quality={80}
                format="webp"
                loading={index === 0 ? "eager" : "lazy"}
                class={`hidden md:block w-full h-full object-cover transition-opacity duration-300 cabinet-image-desktop ${index === 0 ? "opacity-100" : "opacity-0 absolute inset-0"}`}
                data-cabinet-id={String(cabinet.id)}
              />
              {/* Image mobile */}
              <Image
                src={cabinet.imageMob || cabinet.image}
                alt={cabinet.name}
                width={768}
                height={500}
                quality={80}
                format="webp"
                loading={index === 0 ? "eager" : "lazy"}
                class={`block md:hidden w-full h-full object-cover transition-opacity duration-300 cabinet-image-mobile ${index === 0 ? "opacity-100" : "opacity-0 absolute inset-0"}`}
                data-cabinet-id={String(cabinet.id)}
              />
            </>
          ))
        }
      </div>

      <!-- Contenu -->
      <div class="p-8">
        <div class="flex items-start justify-between gap-4 mb-4">
          <div class="flex-1">
            <h3
              id="cabinet-name"
              class="text-center md:text-left text-2xl font-bold text-[#313181] mb-2"
            >
              {cabinets[0].name}
            </h3>
            <p id="cabinet-description" class="text-center md:text-left text-gray-600">
              {cabinets[0].description}
            </p>
            <p class="text-center md:text-left text-gray-600 mt-2">{cabinets[0].hours}</p>
          </div>
        </div>

        <Link
          id="cabinet-link"
          href={cabinets[0].mapsUrl}
          target="_blank"
          variant="external"
          className="w-full justify-center md:inline-flex md:w-auto"
        >
          Voir sur Google Maps
        </Link>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ cabinetsJSON }}>
  const cabinetsData = JSON.parse(cabinetsJSON);
  const buttons = document.querySelectorAll(".cabinet-btn");
  const nameEl = document.getElementById("cabinet-name");
  const descriptionEl = document.getElementById("cabinet-description");
  const linkEl = document.getElementById("cabinet-link");

  buttons.forEach((btn) => {
    btn.addEventListener("click", function () {
      const cabinetId = this.getAttribute("data-cabinet-id");
      const selected = cabinetsData.find((c) => String(c.id) === String(cabinetId));

      if (!selected) return;

      // Mettre à jour les boutons
      buttons.forEach((b) => {
        // reset état inactif
        b.classList.remove(
          "bg-gradient-to-br",
          "from-[#37A4B3]",
          "to-[#268090]",
          "text-white",
          "shadow-md",
          "border-transparent"
        );

        b.classList.add("bg-white", "text-[#313181]", "border", "border-[#37A4B3]");
      });

      // état actif
      this.classList.add(
        "bg-gradient-to-br",
        "from-[#37A4B3]",
        "to-[#268090]",
        "text-white",
        "shadow-md",
        "border",
        "border-transparent"
      );

      this.classList.remove("bg-white", "text-[#313181]", "border-[#37A4B3]");

      // Cacher toutes les images
      document.querySelectorAll(".cabinet-image-desktop, .cabinet-image-mobile").forEach((img) => {
        img.classList.add("opacity-0", "absolute", "inset-0");
        img.classList.remove("opacity-100");
      });

      // Afficher les images du cabinet sélectionné
      document.querySelectorAll(`[data-cabinet-id="${cabinetId}"]`).forEach((img) => {
        if (img.tagName === "IMG") {
          img.classList.remove("opacity-0", "absolute", "inset-0");
          img.classList.add("opacity-100");
        }
      });

      // Mettre à jour le contenu
      nameEl.textContent = selected.name;
      descriptionEl.textContent = selected.description;
      linkEl.href = selected.mapsUrl;
    });
  });
</script>
