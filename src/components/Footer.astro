---
import Image from "astro/components/Image.astro";
import logoFooter from "../assets/logo/logoCMPwhite.svg";

const navLinks = [
  { label: "Accueil", href: "/" },
  { label: "Nos cabinets", href: "/#our-offices" },
  { label: "Notre équipe", href: "/#our-team" },
  { label: "Questions fréquentes", href: "/#faq" },
];

const legalLinks = [
  { label: "Mentions légales", href: "/legal" },
  // { label: "Conditions d’utilisation", href: "/cgu" },
];
---

<footer class="bg-gray-950 text-gray-300 pt-16 pb-10">
  <div class="max-w-7xl mx-auto px-6 flex gap-8 md:gap-24 md:flex-row flex-col justify-between">
    <!-- Logo + Description -->
    <div class="space-y-4 w-full md:w-100">
      <Image src={logoFooter} alt="Logo" class="w-32 m-auto-0" />

      <p class="text-gray-400 text-sm leading-relaxed">
        Centre de Pneumologie, Alergologie Respiratoire et Oncologie Thoracique à Lyon.
      </p>
    </div>

    <!-- Navigation -->
    <div>
      <p class="text-white font-semibold mb-4">Navigation</p>
      <ul class="space-y-2">
        {
          navLinks.map((link) => (
            <li>
              <a href={link.href} class="hover:underline">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Légal -->
    <div>
      <p class="text-white font-semibold mb-4">Légal</p>
      <ul class="space-y-2">
        {
          legalLinks.map((link) => (
            <li>
              <a href={link.href} class="hover:underline">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-gray-800 mt-14 pt-6 text-center text-sm text-gray-300">
    © {new Date().getFullYear()} — Tous droits réservés.
  </div>
</footer>
