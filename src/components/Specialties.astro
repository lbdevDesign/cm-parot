---
import team from "../data/team.js";
import Link from "./Link.astro";
import { Image } from "astro:assets";
import emptyAvatar from "../assets/medecins/emptyPP.png";

interface Specialty {
  id: string;
  title: string;
  shortDesc: string;
  description: string;
  specialNote?: string;
  doctors?: string[];
}

const specialties: Specialty[] = [
  {
    id: "pneumologie-generale",
    title: "Pneumologie générale",
    shortDesc: "Prise en charge complète des maladies respiratoires de l'adulte",
    description:
      "Nous prenons en charge l'ensemble des maladies respiratoires de l'adulte : asthme, bronchite chronique, BPCO, pathologie interstitielle, infections pulmonaires, essoufflement inexpliqué, toux chronique.",
  },
  {
    id: "oncologie",
    title: "Oncologie thoracique",
    shortDesc: "Diagnostic et suivi des cancers du poumon",
    description:
      "L'expertise du centre médical Parot permet d'assurer le diagnostic et la prise en charge thérapeutique des cancers du poumon. Nous travaillons sur 3 sites hospitaliers répartis sur la métropole de Lyon (Hôpital privé Jean Mermoz, Clinique Charcot et Polyclinique de Rillieux) en collaboration avec des équipes de chirurgie thoracique et de radiothérapie pour que chaque patient bénéficie d'un accompagnement personnalisé de qualité tout au long de son parcours de soins.",
    specialNote:
      "En cas de suspicion de cancer pulmonaire, vous pouvez réaliser une demande de consultation urgente afin d'obtenir un rendez-vous dans un délai de quelques jours.",
  },
  {
    id: "allergologie",
    title: "Allergologie",
    shortDesc: "Diagnostic et traitement des allergies",
    description:
      "Nous prenons en charge le diagnostic et le traitement des allergies, principalement respiratoires, telles que la rhinite allergique ou l'asthme allergique. Des évaluations spécialisées permettent d'identifier les allergènes responsables de vos symptômes et de vous proposer une immunothérapie allergénique (ou désensibilisation). Nous assurons également l'exploration des allergies alimentaires et médicamenteuses, en particulier avec l'hôpital de jour d'allergologie médicamenteuse de l'adulte à la Polyclinique de Rillieux.",
    specialNote: "Pour un problème d'allergie alimentaire ou médicamenteuse : Dr Vial-Dupuy",
  },
  {
    id: "pneumo-pediatrie",
    title: "Pneumo-pédiatrie",
    shortDesc: "Troubles respiratoires de l'enfant et l'adolescent",
    description:
      "La pneumo-pédiatrie est dédiée aux troubles respiratoires de l'enfant et de l'adolescent. Nous accompagnons les jeunes patients à partir de l'âge de 6 ans, dans le diagnostic et le suivi de pathologies telles que l'asthme de l'enfant, les allergies respiratoires ou les infections à répétition.",
  },
  {
    id: "fibroscopie",
    title: "Fibroscopie bronchique",
    shortDesc: "Exploration de l'intérieur des voies respiratoires",
    description:
      "La fibroscopie bronchique est un examen permettant d'explorer l'intérieur des voies respiratoires (trachée et bronches) à l'aide d'un endoscope souple. Cet examen est indiqué pour le bilan diagnostique de certaines pathologies pulmonaires, notamment d'origine tumorale ou infectieuse. L'examen permet de réaliser des prélèvements pour des recherches à visée microbiologique et des biopsies pour analyse anatomopathologique. Il peut être réalisé selon votre préférence sous anesthésie locale ou sous anesthésie générale avec un délai de moins d'une semaine pour les indications urgentes. Les fibroscopies bronchiques sont réalisées sur 3 sites : Hôpital privé Jean Mermoz, Clinique Charcot et Polyclinique de Rillieux.",
    specialNote:
      "L'hôpital Privé Jean Mermoz est équipé pour la réalisation des échoendoscopies bronchiques (EBUS). Le Dr Veaudor pratique également l'échoendoscopie.",
  },
  {
    id: "sommeil",
    title: "Troubles respiratoires du sommeil",
    shortDesc: "Diagnostic du syndrome d'apnées du sommeil",
    description:
      "Les troubles respiratoires du sommeil, comme le syndrome d'apnées du sommeil, peuvent avoir un impact important sur la santé et la qualité de vie. Ils se manifestent souvent par des ronflements, une fatigue persistante ou une somnolence dans la journée. Un bilan spécialisé permet d'établir le diagnostic et de proposer des solutions efficaces pour retrouver un sommeil réparateur. Notre centre propose des examens diagnostics en ambulatoire (nuit à domicile) et également en hospitalisation (Hôpital Privé Jean Mermoz) par polygraphie ventilatoire ou polysomnographie (polygraphie ventilatoire + électro-encéphalogramme).",
    specialNote: "Pour une Polysomnographie : Dr Wattiez, Dr Hanin, Dr Jouan, Dr Bouledrak",
  },
];

// Générer dynamiquement la liste des docteurs pour chaque spécialité
specialties.forEach((specialty) => {
  specialty.doctors = team
    .filter((doctor) => doctor.specialties.includes(specialty.id))
    .map((doctor) => {
      const notes = doctor.specialtyNotes as Record<string, string> | undefined;
      const note = notes?.[specialty.id];
      return note ? `${doctor.displayName} ${note}` : doctor.displayName;
    });
});
---

<section
  class="w-full scroll-mt-25 pt-20 pb-10 bg-gradient-to-b from-white to-[--brand-surface]"
  id="expertises"
>
  <div class="max-w-7xl mx-auto px-6">
    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-[#313181] mb-4">Nos domaines d'expertise</h2>
      <p class="text-lg text-gray-600 max-w-3xl mx-auto">
        Une équipe pluridisciplinaire pour une prise en charge complète de vos besoins respiratoires
      </p>
    </div>

    <!-- Grille des blocs cliquables -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        specialties.map((specialty) => (
          <button
            data-specialty={specialty.id}
            aria-label={`Voir les détails sur ${specialty.title}`}
            class="relative overflow-hidden specialty-card p-4 bg-white rounded-2xl border-2 border-gray-200 hover:border-[#37A4B3] hover:shadow-xl transition-all duration-300 group cursor-pointer text-left h-full flex flex-col"
          >
            <div class="w-full rounded-lg bg-gradient-to-br from-[#37A4B3] to-[#268090] p-6 group-hover:from-[#268090] group-hover:to-[#1F6B78] transition-all duration-300 min-h-[100px] flex items-center relative overflow-hidden">
              <div class="absolute -right-6 -top-6 w-24 h-24 rounded-full bg-white/10 group-hover:scale-110 transition-transform duration-300" />
              <div class="absolute -right-2 top-12 w-16 h-16 rounded-full bg-white/5 group-hover:scale-110 transition-transform duration-300" />
              <h3 class="text-xl font-bold text-white relative z-10">{specialty.title}</h3>
            </div>

            <div class="p-6 flex-1 flex flex-col">
              <p class="text-gray-600 text-sm mb-4 flex-1">{specialty.shortDesc}</p>

              <div class="flex items-center gap-2 text-[#37A4B3] font-semibold text-sm">
                En savoir plus
                <svg
                  class="h-4 w-4 group-hover:translate-x-1 transition-transform"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5l7 7-7 7"
                  />
                </svg>
              </div>
            </div>
          </button>
        ))
      }
    </div>
  </div>
</section>

<!-- Panneau latéral (Side Panel) -->
<div
  id="specialty-panel"
  class="fixed inset-y-0 right-0 w-full md:w-[600px] bg-white shadow-2xl z-[200] transform translate-x-full transition-transform duration-300 flex flex-col"
  role="dialog"
  aria-labelledby="panel-title"
  aria-modal="true"
>
  <!-- Header du panneau -->
  <div
    class="flex-shrink-0 bg-gradient-to-br from-[#37A4B3] to-[#268090] text-white px-6 py-6 flex justify-between items-center"
  >
    <h2 id="panel-title" class="text-2xl text-white font-bold"></h2>
    <button
      id="close-panel"
      aria-label="Fermer le panneau"
      class="text-white hover:bg-white hover:bg-opacity-20 rounded-full p-2 transition-all"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <!-- Contenu du panneau (SCROLLABLE) -->
  <div class="flex-1 overflow-y-auto p-6 space-y-6">
    <!-- Description -->
    <div>
      <h3 class="text-lg font-bold text-[#313181] mb-3">Description</h3>
      <p id="panel-description" class="text-gray-600 leading-relaxed"></p>
    </div>

    <!-- Note spéciale si existe -->
    <div id="panel-note-container" class="hidden">
      <div class="bg-[#37A4B3] bg-opacity-10 border-l-4 border-[#37A4B3] p-4 rounded">
        <p id="panel-note" class="text-white text-sm"></p>
      </div>
    </div>

    <!-- Praticiens -->
    <div>
      <h3 class="text-lg font-bold text-[#313181] mb-4">Praticiens disponibles</h3>
      <div id="panel-doctors" class="space-y-3 flex flex-col">
        {
          team.map((doctor) => (
            <div class="doctor-card hidden" data-doctor={doctor.displayName}>
              <div class="flex items-center gap-3 p-3 hover:bg-gray-50 rounded-lg transition-all group">
                <div class="w-12 h-12 rounded-full overflow-hidden border-2 border-[#37A4B3]/20 group-hover:border-[#37A4B3] flex-shrink-0 flex items-center justify-center transition-colors">
                  {doctor.photo ? (
                    <Image
                      src={doctor.photo}
                      alt={doctor.displayName}
                      width={48}
                      height={48}
                      quality={80}
                      loading="lazy"
                      class="w-full h-full object-cover object-top"
                    />
                  ) : (
                    <Image
                      src={emptyAvatar}
                      alt={doctor.name}
                      width={48}
                      height={48}
                      loading="lazy"
                      class="w-full h-full object-cover object-center"
                    />
                  )}
                </div>
                <div class="flex-1 min-w-0">
                  <span class="doctor-name font-medium text-[#313181] text-sm block">
                    {doctor.displayName}
                  </span>
                </div>
                {doctor.url && (
                  <div class="flex-shrink-0">
                    <Link href={doctor.url} target="_blank" variant="external">
                      Prendre RDV
                    </Link>
                  </div>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</div>

<!-- Overlay (fond sombre) -->
<div
  id="panel-overlay"
  class="fixed inset-0 bg-black bg-opacity-50 backdrop-blur-sm z-[199] opacity-0 pointer-events-none transition-opacity duration-300"
  aria-hidden="true"
>
</div>

<script define:vars={{ specialties, team }}>
  const panel = document.getElementById("specialty-panel");
  const overlay = document.getElementById("panel-overlay");
  const closeBtn = document.getElementById("close-panel");
  const cards = document.querySelectorAll(".specialty-card");

  const panelTitle = document.getElementById("panel-title");
  const panelDescription = document.getElementById("panel-description");
  const panelDoctors = document.getElementById("panel-doctors");
  const panelNote = document.getElementById("panel-note");
  const panelNoteContainer = document.getElementById("panel-note-container");

  let panelOpen = false;

  function openPanel(specialtyId) {
    const specialty = specialties.find((s) => s.id === specialtyId);
    if (!specialty) return;

    panelTitle.textContent = specialty.title;
    panelDescription.textContent = specialty.description;

    const allDoctorCards = panelDoctors.querySelectorAll(".doctor-card");
    allDoctorCards.forEach((card) => card.classList.add("hidden"));

    const sortedDoctors = [...specialty.doctors].sort((a, b) => {
      const nameA = a.split("(")[0].trim().split(" ")[1] || a;
      const nameB = b.split("(")[0].trim().split(" ")[1] || b;
      return nameA.localeCompare(nameB);
    });

    sortedDoctors.forEach((doctorName, index) => {
      const cleanName = doctorName.split("(")[0].trim();
      const card = panelDoctors.querySelector(`[data-doctor="${cleanName}"]`);

      if (card) {
        const nameEl = card.querySelector(".doctor-name");
        if (nameEl) {
          nameEl.textContent = doctorName;
        }

        card.style.order = index;
        card.classList.remove("hidden");
      }
    });

    if (specialty.specialNote) {
      panelNote.textContent = specialty.specialNote;
      panelNoteContainer.classList.remove("hidden");
    } else {
      panelNoteContainer.classList.add("hidden");
    }

    const scrollableContent = panel.querySelector(".overflow-y-auto");
    if (scrollableContent) {
      scrollableContent.scrollTop = 0;
    }

    panel.classList.remove("translate-x-full");
    overlay.classList.remove("opacity-0", "pointer-events-none");
    overlay.classList.add("opacity-75", "pointer-events-auto");
    document.body.style.overflow = "hidden";

    panelOpen = true;
    window.history.pushState({ panelOpen: true }, "");
  }

  function closePanel() {
    panel.classList.add("translate-x-full");
    overlay.classList.add("opacity-0", "pointer-events-none");
    overlay.classList.remove("opacity-75", "pointer-events-auto");
    document.body.style.overflow = "";

    panelOpen = false;
  }

  cards.forEach((card) => {
    card.addEventListener("click", () => {
      const specialtyId = card.getAttribute("data-specialty");
      openPanel(specialtyId);
    });
  });

  closeBtn?.addEventListener("click", () => {
    closePanel();
    if (window.history.state?.panelOpen) {
      window.history.back();
    }
  });

  overlay?.addEventListener("click", () => {
    closePanel();
    if (window.history.state?.panelOpen) {
      window.history.back();
    }
  });

  window.addEventListener("popstate", (event) => {
    if (panelOpen) {
      closePanel();
    }
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !panel.classList.contains("translate-x-full")) {
      closePanel();
      if (window.history.state?.panelOpen) {
        window.history.back();
      }
    }
  });
</script>
