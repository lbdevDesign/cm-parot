---
import { Image } from "astro:assets";
import Link from "./Link.astro";
import team from "../data/team.js";
import emptyAvatar from "../assets/medecins/emptyPP.png";

interface TeamMember {
  name: string;
  displayName: string;
  url: string;
  photo: any;
  specialties: string[];
  specialtyNotes?: Record<string, string>;
  description: string | null;
}

const sortedTeam = [...(team as TeamMember[])].sort((a, b) =>
  a.name.localeCompare(b.name, "fr", { sensitivity: "base" })
);

// Mapping des IDs de spécialités vers leurs noms
const specialtyNames: Record<string, string> = {
  "pneumologie-generale": "Pneumologie générale",
  "pneumo-pediatrie": "Pneumo-pédiatrie",
  allergologie: "Allergologie",
  oncologie: "Oncologie thoracique",
  fibroscopie: "Fibroscopie bronchique",
  sommeil: "Troubles du sommeil",
};

// Fonction pour obtenir les noms de spécialités d'un médecin
function getSpecialtyLabels(specialtyIds: string[]): string {
  return specialtyIds
    .map((id) => specialtyNames[id])
    .filter(Boolean)
    .join(" • ");
}
---

<section class="w-full scroll-mt-25 pt-10 pb-10" id="equipe">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="text-3xl md:text-4xl text-[#313181] font-bold text-center mb-4">Notre équipe</h2>
    <p class="text-center text-gray-600 mb-12">
      Des médecins pneumologues expérimentés à votre écoute
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {
        sortedTeam.map((member, index) => (
          <button
            data-modal-id={`modal-${index}`}
            class={`doctor-card bg-white rounded-2xl border border-gray-200 hover:border-[#37A4B3] transition-all duration-300 overflow-hidden shadow-sm hover:shadow-md group/card text-left w-full ${member.description ? "cursor-pointer" : ""}`}
          >
            <div class="p-6 flex flex-col md:flex-row items-center gap-6">
              <div class="relative w-28 h-28 rounded-full overflow-hidden border-4 border-[#37A4B3]/20 group-hover/card:border-[#37A4B3] transition-colors flex-shrink-0">
                {member.photo ? (
                  <Image
                    src={member.photo}
                    alt={member.name}
                    width={112}
                    height={112}
                    quality={85}
                    loading={index < 4 ? "eager" : "lazy"}
                    class="w-full h-full object-cover object-top"
                  />
                ) : (
                  <Image
                    src={emptyAvatar}
                    alt={member.name}
                    width={112}
                    height={112}
                    loading="lazy"
                    class="w-full h-full object-cover object-center"
                  />
                )}

                {/* Overlay en bas avec icône info */}
                {member.description && (
                  <div class="absolute bottom-0 left-0 right-0 h-10 bg-gradient-to-t from-black/90 to-transparent flex items-end justify-center pb-1 opacity-0 group-hover/card:opacity-100 transition-opacity duration-300">
                    <svg
                      class="w-5 h-5 text-white"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                      />
                    </svg>
                  </div>
                )}
              </div>

              <div class="flex-1 flex flex-col items-center md:items-start gap-3">
                <div>
                  <h3 class="text-center md:text-left text-xl font-semibold text-[#313181] mb-1">
                    {member.name}
                  </h3>
                  <p class="text-center md:text-left text-gray-600 text-sm">
                    {getSpecialtyLabels(member.specialties)}
                  </p>
                </div>

                <Link
                  href={member.url}
                  variant="external"
                  target="_blank"
                  className="w-full justify-center pointer-events-auto"
                >
                  Prendre RDV
                </Link>
              </div>
            </div>
          </button>
        ))
      }
    </div>
  </div>
</section>

<!-- Modales pré-rendues pour chaque médecin -->
{
  sortedTeam.map((member, index) =>
    member.description ? (
      <div
        id={`modal-${index}`}
        class="doctor-modal fixed inset-0 bg-black/50 backdrop-blur-sm z-[250] opacity-0 pointer-events-none transition-opacity duration-300 flex items-center justify-center p-4"
        role="dialog"
        aria-labelledby={`modal-name-${index}`}
        aria-modal="true"
      >
        <div class="modal-content bg-white rounded-2xl shadow-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto transform scale-95 opacity-0 transition-all duration-300">
          {/* Header - STICKY */}
          <div class="sticky top-0 z-10 bg-gradient-to-br from-[#37A4B3] to-[#268090] p-6 flex flex-col md:flex-row items-center md:items-start gap-6">
            {member.photo ? (
              <Image
                src={member.photo}
                alt={member.name}
                width={96}
                height={96}
                quality={85}
                class="w-24 h-24 rounded-full border-4 border-white/30 object-cover object-top flex-shrink-0"
              />
            ) : (
              <Image
                src={emptyAvatar}
                alt={member.name}
                width={96}
                height={96}
                class="w-24 h-24 rounded-full border-4 border-white/30 object-cover object-center flex-shrink-0"
              />
            )}

            <div class="flex-1">
              <h2
                id={`modal-name-${index}`}
                class="text-2xl text-center md:text-left font-bold text-white mb-2"
              >
                {member.name}
              </h2>
              <p class="text-white/90 text-center md:text-left text-sm">
                {getSpecialtyLabels(member.specialties)}
              </p>
            </div>

            <button
              class="close-modal absolute top-2 right-2 text-white hover:bg-white/20 rounded-full p-2 transition-all flex-shrink-0"
              aria-label="Fermer la modale"
            >
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M6 18L18 6M6 6l12 12"
                />
              </svg>
            </button>
          </div>

          {/* Body */}
          <div class="p-6 space-y-6">
            <div>
              <h3 class="text-lg font-bold text-[#313181] mb-3">Présentation</h3>
              <p class="text-gray-600 leading-relaxed">{member.description}</p>
            </div>

            <div class="pt-4 border-t border-gray-200">
              <Link href={member.url} variant="external" target="_blank">
                Prendre RDV
              </Link>
            </div>
          </div>
        </div>
      </div>
    ) : null
  )
}

<script>
  const doctorCards = document.querySelectorAll(".doctor-card");

  doctorCards.forEach((card) => {
    card.addEventListener("click", (e) => {
      // Ne pas ouvrir si on clique sur le bouton Doctolib
      if ((e.target as Element).closest("a")) return;

      const modalId = card.getAttribute("data-modal-id");
      if (!modalId) return;

      const modal = document.getElementById(modalId);
      if (!modal) return;

      openModal(modal);
    });
  });

  function openModal(modal: HTMLElement) {
    const modalContent = modal.querySelector(".modal-content");
    if (!modalContent) return;

    modal.classList.remove("opacity-0", "pointer-events-none");
    modal.classList.add("opacity-100", "pointer-events-auto");

    setTimeout(() => {
      modalContent.classList.remove("scale-95", "opacity-0");
      modalContent.classList.add("scale-100", "opacity-100");
    }, 10);

    document.body.style.overflow = "hidden";
  }

  function closeModal(modal: HTMLElement) {
    const modalContent = modal.querySelector(".modal-content");
    if (!modalContent) return;

    modalContent.classList.add("scale-95", "opacity-0");
    modalContent.classList.remove("scale-100", "opacity-100");

    setTimeout(() => {
      modal.classList.add("opacity-0", "pointer-events-none");
      modal.classList.remove("opacity-100", "pointer-events-auto");
    }, 200);

    document.body.style.overflow = "";
  }

  // Fermeture des modales
  document.querySelectorAll(".close-modal").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      const modal = (e.target as Element).closest(".doctor-modal");
      if (modal) closeModal(modal as HTMLElement);
    });
  });

  document.querySelectorAll(".doctor-modal").forEach((modal) => {
    modal.addEventListener("click", (e) => {
      if (e.target === modal) {
        closeModal(modal as HTMLElement);
      }
    });
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      const openModal = document.querySelector(".doctor-modal.opacity-100");
      if (openModal) closeModal(openModal as HTMLElement);
    }
  });
</script>
