---
// Bannière + popup dépistage cancer du poumon (essai IMPULSION)
---

<!-- Bannière cliquable sous la hero section -->
<div class="max-w-7xl mx-auto px-6 pt-12 pb-3">
  <div
    id="depistage-banner"
    class="cursor-pointer group rounded-2xl px-7 py-5 flex items-center justify-between gap-6 shadow-sm hover:shadow-md transition-shadow duration-200"
    style="background: linear-gradient(135deg, #313181, #1f2458);"
    role="button"
    tabindex="0"
    aria-label="Participer au dépistage du cancer du poumon - Cliquez pour en savoir plus"
  >
    <div class="flex flex-col gap-1 text-white min-w-0">
      <p class="text-lg md:text-xl font-bold leading-tight">Dépistage du cancer du poumon</p>
      <p class="text-sm md:text-base opacity-80 leading-snug">
        Essai IMPULSION sur le site de Mermoz. Cliquez pour en savoir plus.
      </p>
    </div>
    <svg
      class="shrink-0 h-4 w-4 text-white opacity-70 group-hover:translate-x-1 transition-transform duration-200"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
    </svg>
  </div>
</div>

<!-- Popup / Modale -->
<div
  id="depistage-modal"
  class="fixed inset-0 z-[100] pointer-events-none transition-opacity duration-300 flex items-center justify-center p-4"
  style="background-color: rgba(0, 0, 0, 0.5); backdrop-filter: blur(4px); opacity: 0;"
  role="dialog"
  aria-modal="true"
  aria-labelledby="depistage-modal-title"
>
  <div
    id="depistage-modal-content"
    class="bg-white rounded-2xl shadow-2xl max-w-lg w-full transform scale-95 transition-transform duration-300 overflow-hidden"
  >
    <!-- Header -->
    <div
      class="text-white px-6 py-5 rounded-t-2xl flex justify-between items-center gap-4"
      style="background: linear-gradient(135deg, #313181, #1f2458);"
    >
      <h2 id="depistage-modal-title" class="text-xl text-white font-bold leading-snug">
        Dépistage du cancer du poumon
      </h2>
      <button
        id="close-depistage-modal"
        class="shrink-0 text-white hover:bg-white/20 rounded-full p-2 transition-all mt-0.5"
        aria-label="Fermer"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Contenu -->
    <div class="p-6 space-y-5 text-sm text-gray-700">
      <p class="leading-relaxed">
        Le centre médical PAROT vous propose de participer au <strong
          >dépistage du cancer du poumon</strong
        >
        dans le cadre de l'essai <strong>IMPULSION</strong> sur son site de Mermoz.
      </p>

      <div class="bg-blue-50 border border-blue-100 rounded-xl p-4 space-y-2">
        <p class="font-semibold text-gray-800 mb-3">Vous êtes concerné(e) si :</p>
        <div class="flex items-start gap-2">
          <span
            class="mt-0.5 shrink-0 h-5 w-5 rounded-full flex items-center justify-center text-white text-xs font-bold"
            style="background-color: #313181;">✓</span
          >
          <p>Vous avez <strong>entre 50 et 74 ans</strong></p>
        </div>
        <div class="flex items-start gap-2">
          <span
            class="mt-0.5 shrink-0 h-5 w-5 rounded-full flex items-center justify-center text-white text-xs font-bold"
            style="background-color: #313181;">✓</span
          >
          <p>Un <strong>tabagisme important</strong> en cours ou sevré depuis moins de 15 ans</p>
        </div>
      </div>

      <div class="pt-1 border-t border-gray-100 space-y-2">
        <p class="text-xs text-gray-500 mb-2">
          Pour plus d'informations ou pour prendre rendez-vous :
        </p>
        <a
          href="tel:0437537888"
          class="flex items-center gap-3 w-full px-5 py-3.5 rounded-xl text-white font-bold text-base transition-all hover:opacity-90 hover:shadow-md"
          style="background-color: #313181;"
        >
          <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
            ></path>
          </svg>
          04 37 53 78 88
        </a>
        <div
          class="flex items-center rounded-xl border overflow-hidden text-sm"
          style="border-color: #313181;"
        >
          <a
            href="mailto:depistage.mermoz@ramsaysante.fr"
            class="flex items-center gap-3 flex-1 min-w-0 px-5 py-3.5 font-medium text-gray-700 hover:bg-blue-50 transition-all"
          >
            <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #313181;">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <span class="truncate">depistage.mermoz@ramsaysante.fr</span>
          </a>
          <button
            id="copy-email-btn"
            aria-label="Copier l'adresse email"
            class="shrink-0 px-4 py-3.5 border-l transition-all hover:bg-blue-50 cursor-pointer flex items-center gap-1.5"
            style="border-color: #313181;"
          >
            <!-- Icône copier (état par défaut) -->
            <svg id="copy-icon" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #313181;">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
            <!-- État copié -->
            <span id="copy-confirm" class="items-center gap-1.5 text-xs font-medium whitespace-nowrap" style="color: #37A4B3; display: none;">
              <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Copié !
            </span>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const STORAGE_KEY = "depistage_popup_last_shown";
  const ONE_WEEK_MS = 24 * 60 * 60 * 1000;

  const modal = document.getElementById("depistage-modal");
  const modalContent = document.getElementById("depistage-modal-content");
  const banner = document.getElementById("depistage-banner");
  const closeBtn = document.getElementById("close-depistage-modal");

  function openModal() {
    modal?.classList.remove("pointer-events-none");
    modal?.classList.add("pointer-events-auto");
    if (modal) modal.style.opacity = "1";
    modalContent?.classList.remove("scale-95");
    modalContent?.classList.add("scale-100");
    document.body.style.overflow = "hidden";
  }

  function closeModal() {
    modal?.classList.add("pointer-events-none");
    modal?.classList.remove("pointer-events-auto");
    if (modal) modal.style.opacity = "0";
    modalContent?.classList.add("scale-95");
    modalContent?.classList.remove("scale-100");
    document.body.style.overflow = "";
    localStorage.setItem(STORAGE_KEY, Date.now().toString());
  }

  function shouldShowPopup(): boolean {
    const lastShown = localStorage.getItem(STORAGE_KEY);
    if (!lastShown) return true;
    return Date.now() - parseInt(lastShown, 10) > ONE_WEEK_MS;
  }

  // Auto-affichage après 5 secondes (une fois par semaine)
  if (shouldShowPopup()) {
    setTimeout(openModal, 2000);
  }

  // Bannière ouvre la popup
  banner?.addEventListener("click", openModal);
  banner?.addEventListener("keydown", (e) => {
    if (e.key === "Enter" || e.key === " ") {
      e.preventDefault();
      openModal();
    }
  });

  // Copier l'email
  const copyBtn = document.getElementById("copy-email-btn");
  const copyIcon = document.getElementById("copy-icon");
  const copyConfirm = document.getElementById("copy-confirm");

  copyBtn?.addEventListener("click", async () => {
    try {
      await navigator.clipboard.writeText("depistage.mermoz@ramsaysante.fr");
    } catch {
      // Fallback si l'API clipboard n'est pas disponible
      const ta = document.createElement("textarea");
      ta.value = "depistage.mermoz@ramsaysante.fr";
      ta.style.position = "fixed";
      ta.style.opacity = "0";
      document.body.appendChild(ta);
      ta.select();
      document.execCommand("copy");
      document.body.removeChild(ta);
    }
    if (copyIcon) copyIcon.style.display = "none";
    if (copyConfirm) copyConfirm.style.display = "flex";
    setTimeout(() => {
      if (copyConfirm) copyConfirm.style.display = "none";
      if (copyIcon) copyIcon.style.display = "";
    }, 2000);
  });

  // Fermeture
  closeBtn?.addEventListener("click", closeModal);

  modal?.addEventListener("click", (e) => {
    if (e.target === modal) closeModal();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && modal && modal.style.opacity === "1") closeModal();
  });
</script>
