---
import Layout from "../layouts/Layout.astro";
import Hero from "@/components/Hero.astro";
import OurOffices from "@/components/OurOffices.astro";
import OurTeam from "@/components/OurTeam.astro";
import FAQ from "@/components/FAQ.astro";
import cabinets from "@/data/cabinets.js";
import ContactBubble from "@/components/ContactBubble.astro";
import Partners from "@/components/Partners.astro";
import Specialties from "@/components/Specialties.astro";

const title = "Centre Médical Parot | Cabinet de Pneumologie Lyon";
const descritpion =
  "Pneumologues à Lyon, Rillieux et Sainte-Foy. Spécialistes en maladies respiratoires, allergologie, apnée du sommeil et oncologie thoracique.";
const image = "/image/og-image.jpg";
---

<Layout title={title} description={descritpion} image={image}>
  <Hero />
  <Specialties />
  <OurOffices client:load cabinets={cabinets} />
  <OurTeam />
  <Partners />
  <FAQ />
  <ContactBubble />
</Layout>
